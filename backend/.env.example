# Clerk backend secret key used to verify session tokens; get it from the Clerk dashboard API keys page.
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Groq API key used for script generation; get it from the Groq developer console.
GROQ_API_KEY=gsk_your_groq_api_key_here

# Pexels API key used to fetch scene footage; get it from the Pexels developer portal.
PEXELS_API_KEY=pexels_your_api_key_here

# Cloudinary cloud name used for final video hosting; get it from your Cloudinary dashboard.
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name

# Cloudinary API key used to upload rendered videos; get it from your Cloudinary dashboard.
CLOUDINARY_API_KEY=your_cloudinary_api_key

# Cloudinary API secret used to authenticate uploads; get it from your Cloudinary dashboard.
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Supabase project URL used for database-backed storage; get it from your Supabase project settings.
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key used for privileged backend access; get it from your Supabase API settings.
SUPABASE_KEY=your_supabase_service_role_key_here

# Direct Postgres connection string for asyncpg; get it from the Supabase database connection settings.
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Stripe secret key used to create checkout sessions; get it from the Stripe developers API keys page.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe webhook secret used to verify billing webhooks; get it from the Stripe webhook endpoint settings.
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Frontend base URL used for billing redirect links; set it to your local or deployed frontend origin.
FRONTEND_APP_URL=http://localhost:5173

# Redis URL used for persistent job state storage; get it from Upstash, Railway, or your Redis provider.
REDIS_URL=redis://localhost:6379/0

# Celery broker/backend URL used for background worker dispatch; usually reuse the same Redis URL.
CELERY_BROKER_URL=redis://localhost:6379/0

# Sentry DSN used for backend error monitoring; get it from your Sentry project settings.
SENTRY_DSN=https://your-backend-sentry-dsn@o0.ingest.sentry.io/0

# LiveKit server URL for FRIDAY voice assistant; get it from your LiveKit Cloud project.
LIVEKIT_URL=wss://your-project.livekit.cloud

# LiveKit API key for signing room tokens; get it from the LiveKit Cloud API keys page.
LIVEKIT_API_KEY=your_livekit_api_key_here

# LiveKit API secret for signing room tokens; get it from the LiveKit Cloud API keys page.
LIVEKIT_API_SECRET=your_livekit_api_secret_here

# Internal URL of the Prompt-to-Reel backend used by the FRIDAY voice agent.
REEL_API_URL=http://localhost:8000
